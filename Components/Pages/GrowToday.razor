<div class="mt-16 mb-12">
    @* Header row *@
    <div class="flex items-start justify-between mb-10">
        <h2 class="text-6xl font-semibold leading-tight">Let's Build Together</h2>
        <button onclick="openContactModal()"
                class="bg-blue-600 text-white px-10 py-8 rounded-sm text-sm font-bold tracking-widest uppercase hover:bg-blue-700 transition-colors cursor-pointer shrink-0">
            WORK WITH ME
        </button>
    </div>

    @* Bento Grid *@
    <div class="grid grid-cols-12 auto-rows-[200px] gap-3">

        @* Row 1 — 3 cards *@

        @* Card 1 — Years of experience (wide) *@
        <div class="col-span-5 row-span-2 rounded-xl overflow-hidden bg-black flex flex-col justify-end p-6">
            <span class="text-6xl font-black text-white">5+</span>
            <p class="text-sm text-gray-400 mt-2">Years of Experience</p>
        </div>

        @* Card 2 — Available for hire *@
        <div class="col-span-3 rounded-xl bg-blue-600 flex flex-col items-center justify-center p-5">
            <div class="w-3 h-3 rounded-full bg-green-400 mb-2 animate-pulse"></div>
            <h3 class="text-white text-sm font-bold tracking-widest uppercase text-center">AVAILABLE<br />FOR HIRE</h3>
        </div>

        @* Card 3 — What I build (tall) *@
        <div class="col-span-4 row-span-2 rounded-xl overflow-hidden bg-gray-950 flex flex-col justify-end p-6">
            <span class="text-xs font-bold tracking-wider uppercase text-blue-400 mb-3">I Build</span>
            <div class="space-y-1.5">
                <p class="text-sm text-gray-300">Web Apps</p>
                <p class="text-sm text-gray-300">APIs</p>
                <p class="text-sm text-gray-300">SaaS Products</p>
                <p class="text-sm text-gray-300">E-Commerce</p>
                <p class="text-sm text-gray-300">Landing Pages</p>
            </div>
        </div>

        @* Row 2 — fills remaining space beside tall cards *@

        @* Card 4 — Testimonial *@
        <div class="col-span-3 rounded-xl bg-white p-5 flex flex-col justify-between border border-gray-200">
            <p class="text-sm text-gray-800 font-medium leading-snug">"Abdulkareem delivered exactly what we needed —
                clean code, fast turnaround."</p>
                <p class="text-xs text-gray-400 mt-3">— Client Review</p>
            </div>

            @* Row 3 — mixed widths based on content *@

            @* Card 5 — C# *@
            <div class="col-span-2 rounded-xl bg-black flex items-center justify-center p-5">
                <div class="text-center">
                    <span class="text-3xl font-black text-white">C#</span>
                    <p class="text-xs text-gray-400 mt-1">Primary Language</p>
                </div>
            </div>

            @* Card 6 — .NET *@
            <div class="col-span-2 rounded-xl bg-white flex items-center justify-center p-5 border border-gray-200">
                <div class="text-center">
                    <span class="text-3xl font-black text-black">.NET</span>
                    <p class="text-xs text-gray-400 mt-1">Core Stack</p>
                </div>
            </div>

            @* Card 7 — Projects delivered (wider) *@
            <div class="col-span-4 rounded-xl overflow-hidden bg-gray-900 flex flex-col justify-end p-6">
                <span class="text-5xl font-black text-white">20+</span>
                <p class="text-sm text-gray-400 mt-2">Projects Delivered</p>
            </div>

            @* Card 8 — Fast Delivery *@
            <div class="col-span-2 rounded-xl bg-black flex items-center justify-center p-5">
                <div class="text-center">
                    <span class="text-4xl">⚡</span>
                    <p class="text-sm font-bold text-white mt-1">Fast Delivery</p>
                </div>
            </div>

            @* Card 9 — Blazor *@
            <div class="col-span-2 rounded-xl bg-black flex items-center justify-center p-5">
                <div class="text-center">
                    <span class="text-3xl font-black text-white">Blazor</span>
                    <p class="text-xs text-gray-400 mt-1">Interactive Web</p>
                </div>
            </div>

            @* Row 4 — bottom row *@

            @* Card 10 — Tailwind *@
            <div class="col-span-3 rounded-xl bg-black flex items-center justify-center p-5">
                <div class="text-center">
                    <span class="text-2xl font-black text-white">Tailwind</span>
                    <p class="text-xs text-gray-400 mt-1">CSS Framework</p>
                </div>
            </div>

            @* Card 11 — Testimonial 2 (wide) *@
            <div class="col-span-5 rounded-xl bg-white p-5 flex flex-col justify-between border border-gray-200">
                <p class="text-sm text-gray-800 font-medium leading-snug">"Working with Abdulkareem was seamless. He
                    understood the requirements and shipped quality code on time."</p>
                    <p class="text-xs text-gray-400 mt-3">— Client Review</p>
                </div>

                @* Card 12 — Fast Delivery repeat → Let's Go CTA *@
                <div class="col-span-4 rounded-xl bg-blue-600 flex items-center justify-center p-5 cursor-pointer hover:bg-blue-700 transition-colors"
                     onclick="openContactModal()">
                    <div class="text-center">
                        <h3 class="text-white text-lg font-bold tracking-wider uppercase">Let's Go</h3>
                        <p class="text-xs text-blue-200 mt-1">Start a conversation</p>
                    </div>
                </div>
            </div>
        </div>