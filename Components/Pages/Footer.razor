<footer class="mt-20 bg-black text-white">
    @* Top section *@
    <div class="px-10 pt-14 pb-10">
        <div class="flex items-start justify-between gap-10">
            @* Left — Subscribe *@
            <div class="flex-1">
                <h3 class="text-sm font-bold tracking-widest uppercase mb-6">Subscribe to Stay in Touch.</h3>
                <div class="flex items-center border border-gray-700 rounded-sm overflow-hidden">
                    <input type="email" placeholder="Enter email address.."
                           class="flex-1 bg-transparent px-4 py-3 text-sm text-white placeholder-gray-500 outline-none" />
                    <button class="px-4 py-3 text-gray-400 hover:text-white transition-colors cursor-pointer">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24"
                             stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                        </svg>
                    </button>
                </div>
            </div>

            @* Right — Socials *@
            <div class="flex items-center gap-6 pt-10">
                <a href="https://github.com/" target="_blank"
                       class="flex items-center gap-2 text-sm text-gray-300 hover:text-white transition-colors">
                    GitHub <span>&rarr;</span>
                </a>
                <a href="https://x.com/" target="_blank"
                       class="flex items-center gap-2 text-sm text-gray-300 hover:text-white transition-colors">
                    X (Twitter) <span>&rarr;</span>
                </a>
            </div>
        </div>
    </div>

    @* Bottom bar *@
    <div class="border-t border-gray-800 px-10 py-5">
        <div class="flex items-center justify-between">
            <div class="flex items-center gap-6 text-xs tracking-widest uppercase text-gray-500">
                <a href="/privacy" class="hover:text-white transition-colors cursor-pointer">Privacy Policy</a>
                <span class="hover:text-white transition-colors cursor-pointer"
                      onclick="openContactModal()">Contact</span>
            </div>
            <p class="text-xs text-gray-500">&copy; @DateTime.Now.Year Abdulkareem Alabi. All rights reserved.</p>
        </div>
    </div>
</footer>